{
	"events": [
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Aslan estava aqui."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Agora não está."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Por alguns segundos, você só fica parada, sentada, ouvindo a própria respiração."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "E isso, de algum jeito, não é confortável."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Não é frio — pelo contrário, o ar já carrega o começo da primavera lá fora, leve, com cheiro de madeira úmida e vida voltando devagar. Mas o vazio dentro da cabana parece ignorar isso completamente."
		},
		{
			"choice": "Levantar",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Os passos são lentos."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O olhar percorre a sala como se estivesse procurando algo que deveria estar ali."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Nada fora do lugar."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Mas também... nada certo."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "E então vem a sensação."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Pequena primeiro."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Depois mais forte."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Aquela familiaridade ruim."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Não é aqui."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Não agora."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Mas em algum outro lugar da sua memória."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Ausência."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Silêncio errado."
		}
	],
